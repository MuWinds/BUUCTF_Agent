{
    "llm": {
        "model": "gpt-4o-mini",
        "api_key": "",
        "api_base": "https://api.openai.com/v1"
    },
    "max_history_steps": 15,
    "compression_threshold": 7,
    "checkpoint_dir": "./checkpoints",
    "tool_config": {
        "bash_shell": {
            "shell_path": "bash",
            "working_dir": ".",
            "timeout": 30,
            "login_shell": false,
            "env": {}
        }
    },
    "mcp_server": {},
    "platform": {
        "inputer": {
            "type": "file",
            "file_path": "./question.txt",
            "attachment_dir": "./attachments"
        },
        "submitter": {
            "type": "manual"
        }
    }
}
